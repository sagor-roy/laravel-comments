{
    "name": "sagor-roy/comments",
    "description": "Simple comment system for Laravel 13 with AJAX support",
    "type": "library",
    "license": "MIT",
    "version": "1.0.0",
    "keywords": [
        "laravel",
        "comments",
        "comment-system",
        "laravel13"
    ],
    "require": {
        "php": "^8.3",
        "laravel/framework": "^13.0"
    },
    "autoload": {
        "psr-4": {
            "SagorRoy\\Comments\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "SagorRoy\\Comments\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "SagorRoy\\Comments\\CommentServiceProvider"
            ]
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
